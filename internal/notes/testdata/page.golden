<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>go-htmx — notes</title><link rel="stylesheet" href="/static/css/app.css"><script src="/static/js/htmx.min.js"></script><script src="/static/js/hx-sse.min.js"></script><script src="/static/js/app.js"></script></head><body class="min-h-screen bg-gray-50 text-gray-900 antialiased dark:bg-gray-900 dark:text-gray-100"><div class="mx-auto max-w-2xl px-4 py-10 sm:py-16"><div class="space-y-8"><header class="space-y-1"><h1 class="text-2xl font-semibold tracking-tight">Notes</h1><p class="text-sm text-gray-500 dark:text-gray-400">Example feature: a live, multi-client notes list over Server-Sent Events (Story #4, AD-4's real-time layer).</p></header><form id="note-form" hx-post="/notes" hx-swap="none" class="flex gap-2"><input type="text" name="body" placeholder="Write a note…" autocomplete="off" required class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm placeholder:text-gray-400 focus:border-gray-500 focus:outline-none focus:ring-1 focus:ring-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:placeholder:text-gray-500"> <button type="submit" class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white">Add</button></form><p><span id="notes-count" hx-swap-oob="true" class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">2 notes</span></p><div id="notes-stream" hx-sse:connect="/notes/stream" hx-target="#notes-list" hx-swap="afterbegin" class="hidden"></div><div id="notes-list" class="space-y-3"><div class="note rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-800" id="note-2"><p class="text-sm leading-relaxed">second note</p><time class="mt-1 block text-xs text-gray-400 dark:text-gray-500">2026-01-15 10:35:00</time></div><div class="note rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-800 dark:bg-gray-800" id="note-1"><p class="text-sm leading-relaxed">first note</p><time class="mt-1 block text-xs text-gray-400 dark:text-gray-500">2026-01-15 10:30:00</time></div></div></div></div></body></html>